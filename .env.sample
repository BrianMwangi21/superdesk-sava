# Copy to .env in the Superdesk server directory (or export in your shell) and fill in.
# SAVA reads these at runtime; defaults live in server/sava/default_settings.py.

# Required: your OpenRouter API key (https://openrouter.ai/keys)
SAVA_OPENROUTER_API_KEY=

# Optional overrides
# SAVA_MODEL=openai/gpt-oss-120b
# SAVA_OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
